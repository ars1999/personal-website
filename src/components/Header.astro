---
import Icon from "./Icon.astro";

const navLinks = [
    { href: "/#home", label: "Home" },
    { href: "/#about", label: "About" },
    { href: "/#education", label: "Education" },
    { href: "/#skills", label: "Skills" },
    { href: "/#experience", label: "Experience" },
    { href: "/#projects", label: "Projects" },
    { href: "/#contact", label: "Contact" },
];
---

<header>
    <div class="container header-container">
        <a href="/#home" class="brand">Arushi Jain</a>

        <nav class="nav-links nav-desktop">
            {
                navLinks.map((link) => (
                    <a href={link.href} class="btn btn-borderless btn-sm">
                        {link.label}
                    </a>
                ))
            }
        </nav>

        <div class="header-right">
            <button
                id="theme-switcher"
                class="btn btn-borderless btn-icon-sm"
                aria-label="Toggle theme"
            >
                <span id="sun-icon"><Icon name="sun" size="1.15rem" /></span>
                <span id="moon-icon"><Icon name="moon" size="1.15rem" /></span>
            </button>
            <button
                id="menu-button"
                class="btn btn-borderless btn-icon-sm nav-mobile-toggle"
                aria-label="Open menu"
            >
                <Icon name="bars" size="1.15rem" />
            </button>
        </div>
    </div>

    <div id="menu-screen" class="menu-screen">
        <nav class="nav-links nav-mobile">
            {
                navLinks.map((link) => (
                    <a href={link.href} class="btn btn-borderless">
                        {link.label}
                    </a>
                ))
            }
        </nav>
    </div>
</header>

<script>
    const root = document.documentElement;
    const sunIcon = document.getElementById("sun-icon");
    const moonIcon = document.getElementById("moon-icon");

    const theme = (() => {
        if (
            typeof localStorage !== "undefined" &&
            localStorage.getItem("theme")
        ) {
            return localStorage.getItem("theme");
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            return "dark";
        }
        return "light";
    })();

    if (theme === "dark") root.classList.add("dark");

    const setIcon = () => {
        const isDark = root.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        if (sunIcon) sunIcon.style.display = isDark ? "flex" : "none";
        if (moonIcon) moonIcon.style.display = isDark ? "none" : "flex";
    };
    setIcon();

    document.getElementById("theme-switcher")?.addEventListener("click", () => {
        root.classList.toggle("dark");
        setIcon();
    });

    const menuScreen = document.getElementById("menu-screen");
    const menuButton = document.getElementById("menu-button");
    const toggleMenu = () => menuScreen?.classList.toggle("menu-open");
    menuButton?.addEventListener("click", toggleMenu);
    menuScreen?.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).closest("a")) toggleMenu();
        else if (e.target === menuScreen) toggleMenu();
    });
</script>

<style>
    header {
        height: var(--header-height);
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 20;
        backdrop-filter: blur(12px);
    }
    .header-container {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .brand {
        font-family: "Roboto Slab", serif;
        font-weight: 600;
        font-size: 1.15rem;
        color: var(--color-primary);
    }
    .nav-links {
        display: flex;
        gap: 0.25rem;
    }
    .nav-links a {
        font-weight: 400;
    }
    .nav-desktop {
        display: none;
    }
    @media (min-width: 1024px) {
        .nav-desktop {
            display: flex;
        }
    }
    .header-right {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .btn-icon-sm {
        width: 2.25rem;
        height: 2.25rem;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }
    #sun-icon,
    #moon-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        position: absolute;
        inset: 0;
    }
    .nav-mobile-toggle {
        display: inline-flex;
    }
    @media (min-width: 1024px) {
        .nav-mobile-toggle {
            display: none;
        }
    }

    .menu-screen {
        visibility: hidden;
        opacity: 0;
        position: fixed;
        inset: 0;
        z-index: 15;
        background-color: color-mix(in srgb, var(--color-bg) 96%, transparent);
        backdrop-filter: blur(12px);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity var(--transition-duration);
    }
    .menu-screen.menu-open {
        visibility: visible;
        opacity: 1;
    }
    .nav-mobile {
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }
    .nav-mobile a {
        font-size: 1.2rem;
        padding: 0.6rem 1.5rem;
    }
    @media (min-width: 1024px) {
        .menu-screen {
            display: none;
        }
    }
</style>
